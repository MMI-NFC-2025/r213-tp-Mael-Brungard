---
import Layout from "../../layouts/Layout.astro";
import { addOffre, getAgents } from "../../js/backend.mjs";

let message = "";
if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const response = await addOffre(formData);
    message = response.message;
}
const agents = await getAgents();
---

<Layout>
    <h1 class="text-2xl font-bold text-center p-5">Ajouter une offre</h1>
    <form
        action="/offres/add"
        method="POST"
        enctype="multipart/form-data"
        class="max-w-250 mb-25 mx-auto bg-white p-8 rounded-lg shadow-md flex flex-col gap-4"
    >
        <h2 class="font-bold text-base">Informations de base</h2>
        <div class="flex justify-between gap-2">
            <div class="flex flex-col flex-3 w-full gap-1">
                <label for="nomMaison" class="font-semibold"
                    >Nom de la maison</label
                >
                <input
                    id="nomMaison"
                    type="text"
                    name="nomMaison"
                    placeholder="Nom de la maison"
                    required
                    class="w-full p-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400"
                />
            </div>
            <div class="flex flex-col flex-1 gap-1">
                <label for="prix" class="font-semibold">Prix</label>
                <input
                    type="number"
                    id="prix"
                    name="prix"
                    placeholder="Prix"
                    class="w-full p-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400"
                />
            </div>
        </div>
        <div class="flex justify-between gap-2">
            <div class="flex flex-col flex-3 gap-1">
                <label for="adresse" class="font-semibold">Adresse</label>
                <input
                    id="adresse"
                    type="text"
                    name="adresse"
                    placeholder="Adresse"
                    required
                    class="w-full p-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400"
                />
            </div>
            <div class="flex flex-col flex-1 gap-1">
                <label for="surface" class="font-semibold">Superficie</label>
                <input
                    type="number"
                    id="surface"
                    name="surface"
                    placeholder="Superficie"
                    class="w-full p-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400"
                />
            </div>
        </div>

        <div class="flex flex-col gap-1">
            <h2 class="font-bold text-base">Agencement</h2>
            <div class="flex flex-col gap-1">
                <label for="nbSdb" class="font-semibold"
                    >Nombre de salles de bain</label
                >
                <input
                    type="number"
                    id="nbSdb"
                    name="nbSdb"
                    placeholder="Nombre de salles de bain"
                    class="w-full p-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400"
                />
            </div>
        </div>
        <div class="flex flex-col gap-1">
            <label for="nbChambres" class="font-semibold"
                >Nombre de chambres</label
            >
            <input
                type="number"
                id="nbChambres"
                name="nbChambres"
                placeholder="Nombre de chambres"
                class="w-full p-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400"
            />
        </div>

        <h2 class="font-bold text-base">Autre</h2>
        <div class="flex flex-col gap-1">
            <label for="agent_select" class="font-semibold">Agent</label>
            <select
                name="agent"
                id="agent_select"
                class="w-full p-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400"
            >
                {
                    agents.map((agent) => (
                        <option value={agent.id}>
                            {agent.Nom} {agent.Prenom}
                        </option>
                    ))
                }
            </select>
        </div>
        <div class="flex flex-col gap-1">
            <label for="images" class="font-semibold">Images</label>
            <input
                type="file"
                id="images"
                name="images"
                class="w-full p-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400"
            />
        </div>
        <button
            type="submit"
            class="mt-4 bg-blue-600 text-white font-semibold py-2 px-4 rounded-md hover:bg-blue-700 transition"
            >Ajouter</button
        >
        <p class="text-center text-red-500">{message}</p>
    </form>
</Layout>
