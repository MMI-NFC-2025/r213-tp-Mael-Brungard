---
import { getAgent, getMaisonByAgent } from "../../js/backend.mjs";
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/OffreCard.astro";

const { id } = Astro.params;
const agent = await getAgent(id);
console.log(id);

const maisons = await getMaisonByAgent(id);
---

<Layout titre={agent.Nom}>
    <div class="max-w-3xl mx-auto bg-white rounded-2xl shadow-lg p-6 space-y-6">
        <h2 class="text-3xl text-center font-bold text-gray-800">
            {agent.Nom}
            {agent.Prenom}
        </h2>
    </div>
    <ul
        class="flex flex-wrap justify-center items-start items-center gap-10 p-10"
    >
        {
            maisons.map((maison) => (
                <li>
                    <Card offre={maison} />
                </li>
            ))
        }
    </ul>
</Layout>
